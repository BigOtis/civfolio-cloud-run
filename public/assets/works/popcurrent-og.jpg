          "height": 60
        },
        "sameAs": [
          "https://twitter.com/popcurrent",
          "https://facebook.com/popcurrent",
          "https://instagram.com/popcurrent"
        ]
      },
              "potentialAction": {
          "@type": "SearchAction",
          "target": "https://popcurrent.otisfuse.com/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
