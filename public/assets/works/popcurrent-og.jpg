    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    
    <!-- Default SEO Meta Tags -->
    <meta name="keywords" content="trending news, viral content, breaking news, current events, reddit stories, social media trends" />
    <meta name="author" content="PopCurrent" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    
    <!-- Open Graph Meta Tags (Facebook, LinkedIn) -->
    <!-- Removed default OG tags; dynamic tags are provided at runtime or via /preview -->
    
    <!-- Twitter Card Meta Tags -->
    <!-- Removed default Twitter tags -->
    
    <!-- App/Mobile Meta Tags -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="PopCurrent" />
    <meta name="theme-color" content="#e32c26" />
