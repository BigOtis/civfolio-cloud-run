server {
  listen ${PORT};
  listen [::]:${PORT};
  server_name _;

  root /usr/share/nginx/html;
  index index.html;

  location / {
    try_files $uri $uri.html $uri/ /404.html;
  }

  location /_next/ {
    add_header Cache-Control "public, max-age=31536000, immutable";
    try_files $uri =404;
  }

  location /assets/ {
    add_header Cache-Control "public, max-age=604800";
    try_files $uri =404;
  }
}
